pipeline {
    agent any

    environment {
        SONAR_SERVER = "SonarQubeServer"   // Name configured in Jenkins
        SONAR_HOST_URL = "http://54.67.137.14:9000"  // Your SonarQube server IP
    }

    tools {
        maven "Maven3"   // Configure in Jenkins
        jdk "JDK17"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/sankeerth16/tinku-project.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv("${SONAR_SERVER}") {
                    sh """
                    mvn sonar:sonar \
                    -Dsonar.projectKey=sonar-demo \
                    -Dsonar.host.url=$ http://54.67.137.14:9000/\
                    -Dsonar.login=squ_9e2cc42f6d56ba01d55c8cbebc4309f001820792
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }
}
